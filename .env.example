# ============================================================
# PERFUME BRAND AI — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# ── FAL.AI (Image Generation — REQUIRED) ────────────────────
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_ai_key_here

# ── ANTHROPIC CLAUDE (Captions — Primary) ───────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ── OPENAI (Captions — Fallback if Claude fails) ────────────
# Used automatically when Claude returns 529 Overloaded
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ── GOOGLE GEMINI (Analysis — Optional) ─────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza_your_google_gemini_key_here

# ── HEDRA (Video Generation — REQUIRED for videos) ──────────
# Your Hedra API key
HEDRA_API_KEY=your_hedra_key_here

# ── DEFAULT LORA (pre-fills the UI) ─────────────────────────
# Train your character LoRA via: https://fal.ai/models/fal-ai/flux-lora-fast-training
# Paste the .safetensors URL here:
NEXT_PUBLIC_DEFAULT_LORA_MODEL=https://huggingface.co/youruser/arab-man-lora/resolve/main/lora.safetensors
NEXT_PUBLIC_DEFAULT_LORA_TRIGGER=arabman

# ── DEPRECATED ───────────────────────────────────────────────
# REPLICATE_API_TOKEN=r8_...  ← no longer used
# NEXT_PUBLIC_DEFAULT_LORA_PATH=...  ← renamed to NEXT_PUBLIC_DEFAULT_LORA_MODEL
