# ============================================================
# PERFUME BRAND AI — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# Replicate API (for AI image generation)
# Get your key at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# Anthropic Claude API (for scraping analysis & captions)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ============================================================
# OPTIONAL: Default LoRA configuration
# Train your character LoRA on HuggingFace and paste the ID
# Format: username/model-name (e.g., "myaccount/arab-man-lora")
# ============================================================
NEXT_PUBLIC_DEFAULT_LORA_MODEL=
NEXT_PUBLIC_DEFAULT_LORA_TRIGGER=

# ============================================================
# REPLICATE MODEL IDs (change to upgrade models)
# ============================================================
# Primary model: FLUX Dev with LoRA support
REPLICATE_FLUX_LORA_MODEL=lucataco/flux-dev-lora:091495765fa5ef2725a175a57b276de8ca4ec54f3a66e93ec8ee4e1bd9bfb842
# ControlNet model for bottle fidelity (advanced)
REPLICATE_CONTROLNET_MODEL=xlabs-ai/flux-dev-controlnet:f2c31c31d81278a91b2447a304dae654c64a5d5a2cec513d83ad571763a7c872
