# ============================================================
# PERFUME BRAND AI — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# ── FAL.AI (Image Generation — REQUIRED) ────────────────────
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_ai_key_here

# ── ANTHROPIC CLAUDE (Analysis + Captions — Primary) ────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ── GOOGLE GEMINI (Analysis + Captions — Fallback) ──────────
# Used automatically if Anthropic key fails/missing
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza_your_google_gemini_key_here

# ── DEFAULT LORA (pre-fills the UI) ─────────────────────────
# Train your character LoRA via: https://fal.ai/models/fal-ai/flux-lora-fast-training
# Paste the .safetensors URL here:
NEXT_PUBLIC_DEFAULT_LORA_PATH=https://huggingface.co/youruser/arab-man-lora/resolve/main/lora.safetensors
NEXT_PUBLIC_DEFAULT_LORA_TRIGGER=arabman

# ── REPLICATE (DEPRECATED — replaced by Fal.ai) ─────────────
# REPLICATE_API_TOKEN=r8_...  ← no longer used
